{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Represents a single item for sale in the shop.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The name of the product" },
        "price": { "type": "number", "description": "The price in dollars" },
        "image": { "type": "string", "description": "URL to the product image" },
        "category": { "type": "string", "description": "Category for filtering" },
        "description": { "type": "string", "description": "Detailed description of the product" }
      },
      "required": ["title", "price"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "The collection of physical products available in the shop."
    }
  }
}
